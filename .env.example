# =============================================================================
# AI Ticket Triage & Auto-Routing System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_TIMEOUT=120

# ── Database ──────────────────────────────────────────────────────────────────
# Local:      sqlite+aiosqlite:///./tickets.db   (default — zero setup)
# Azure:      postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./tickets.db

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use an App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_ENABLED=true
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM_NAME=Ticket Triage System
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Routing Config ────────────────────────────────────────────────────────────
ROUTING_CONFIG_PATH=data/routing_config.xlsx

# ── Pipeline Confidence Thresholds ───────────────────────────────────────────
CONFIDENCE_AUTO_ROUTE=0.85
CONFIDENCE_FLAG=0.65

# ── ML Model ─────────────────────────────────────────────────────────────────
ML_MODEL_PATH=src/ml/models/classifier.pkl
ML_VECTORIZER_PATH=src/ml/models/vectorizer.pkl
TRAINING_DATA_PATH=data/sample_tickets.xlsx

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Feedback Retraining ───────────────────────────────────────────────────────
FEEDBACK_RETRAIN_THRESHOLD=20
